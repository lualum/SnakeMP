{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ES2022", "ESNext.AsyncIterable"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "rootDir": "./",
        "outDir": "./dist"
    },
    "include": ["server/**/*.ts", "public/**/*.ts"],
    "exclude": ["node_modules"]
}
