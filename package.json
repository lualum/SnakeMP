{
    "name": "snake-mp",
    "version": "1.0.0",
    "description": "Multiplayer Snake Game",
    "main": "dist/server/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc --build && vite build",
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:server": "tsx watch --tsconfig server/tsconfig.json server/src/index.ts",
        "dev:client": "vite"
    },
    "dependencies": {
        "express": "^4.18.2",
        "ws": "^8.13.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.17",
        "@types/node": "^20.19.41",
        "@types/ws": "^8.5.4",
        "concurrently": "^8.2.2",
        "tsx": "^4.22.3",
        "typescript": "^5.0.0",
        "vite": "^8.0.13"
    }
}