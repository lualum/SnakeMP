{
    "name": "snake-mp",
    "type": "module",
    "version": "1.0.0",
    "description": "Multiplayer Snake Game",
    "main": "dist/server/index.js",
    "scripts": {
        "dev:server": "nodemon --watch dist/server dist/server/index.js",
        "dev:client": "vite",
        "build": "tsc && vite build",
        "dev": "concurrently \"tsc --watch\" \"npm run dev:server\" \"npm run dev:client\""
    },
    "dependencies": {
        "express": "^4.18.2",
        "ws": "^8.13.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.17",
        "@types/node": "^20.0.0",
        "@types/ws": "^8.5.4",
        "concurrently": "^8.2.2",
        "nodemon": "^3.0.1",
        "typescript": "^5.0.0",
        "vite": "^8.0.13"
    }
}