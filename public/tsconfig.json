{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "composite": true,
        "outDir": "../dist/public",
        "rootDir": "./src",
        "tsBuildInfoFile": "../dist/public/.tsbuildinfo",
        "baseUrl": ".",
        "paths": {
            "@shared/*": ["../shared/src/*"]
        }
    },
    "include": ["src"],
    "references": [{ "path": "../shared" }]
}
